; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the format may change at any time.
;
; If you wish to change a setting, do so in this file then
; enable "Editor > Version Control > Autocommit changes" to
; commit it automatically.

[configuration]

config_version=5

[application]

config/name="godot-otel-demo"
config/description="Demo and test project for the godot-otel-gdextension"
config/version="0.1.0"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[editor_plugins]

enabled=PackedStringArray("res://addons/gdunit4/plugin.cfg")
